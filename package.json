{
  "name": "hn-digest",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Source-grounded Hacker News article and discussion digests.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bwright2810/hn-digest.git"
  },
  "bugs": {
    "url": "https://github.com/bwright2810/hn-digest/issues"
  },
  "homepage": "https://github.com/bwright2810/hn-digest#readme",
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build && pnpm build:runtime",
    "build:runtime": "esbuild scripts/production.ts scripts/background.ts scripts/migrate.ts scripts/digest.ts scripts/source-baseline.ts --bundle --platform=node --format=cjs --target=node24 --outdir=.next/runtime --external:jsdom",
    "start": "next start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:rollback": "tsx scripts/db/rollback.ts",
    "db:check": "drizzle-kit check",
    "digest:run": "tsx scripts/digest.ts run",
    "digest:status": "tsx scripts/digest.ts status",
    "source:baseline": "tsx scripts/source-baseline.ts"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "drizzle-orm": "^0.45.2",
    "html-to-text": "^10.0.0",
    "ipaddr.js": "^2.4.0",
    "jsdom": "^29.1.1",
    "next": "^16.2.11",
    "openai": "^6.48.0",
    "pg": "^8.22.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/env": "16.2.11",
    "@playwright/test": "^1.61.1",
    "@types/html-to-text": "^9.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.11",
    "prettier": "^3.9.6",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.10",
      "sharp": "0.35.0"
    }
  }
}
